{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Proxy",
      "type": "shell",
      "command": "dart bin/proxy.dart",
      "options": {
        "cwd": "${workspaceFolder}/eda_app"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "CORS Proxy Server running",
          "endsPattern": "CORS Proxy Server running"
        }
      }
    }
  ]
}
